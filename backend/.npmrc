# ============================================================
# Configuración de Seguridad pnpm - Backend
# Protección contra ataques de cadena de suministro (supply chain)
# ============================================================

# Cuarentena: no instalar paquetes publicados hace menos de 24 horas.
minimum-release-age=1440

# Bloquear fuentes "exóticas" en subdependencias
block-exotic-subdeps=true

# Lockfile estricto en CI/CD
frozen-lockfile=false
