# ============================================================
# Configuración de Seguridad pnpm - Frontend
# Protección contra ataques de cadena de suministro (supply chain)
# ============================================================

# Cuarentena: no instalar paquetes publicados hace menos de 24 horas.
# Esto habría bloqueado el ataque de TanStack (duró solo 6 minutos).
minimum-release-age=1440

# Bloquear fuentes "exóticas" en subdependencias (git URLs, tarballs remotos, etc.)
# Evita que dependencias transitivas jaluen código de fuentes no oficiales.
block-exotic-subdeps=true

# Usar lockfile estricto en CI/CD (instalar exactamente lo del pnpm-lock.yaml)
# En desarrollo local esto es más flexible, pero en CI se debe usar --frozen-lockfile
frozen-lockfile=false

# Verificar firmas de paquetes del registro (disponible en pnpm v11.1.0+)
# registry-supports-time-field=true
